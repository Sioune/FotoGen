OPENAI_API_KEY=sk-your-transfer-key
OPENAI_BASE_URL=https://api.gptsapi.net/v1
OPENAI_IMAGE_MODE=gptsapi-edit
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_ASPECT_RATIO=16:9
OPENAI_IMAGE_RESOLUTION=2K

# 推荐：把上传的参考图保存到公网素材仓库，再把公网 URL 传给 GPTSAPI。
# 你的公网素材仓库需要支持 HTTP PUT 上传。
OPENAI_ASSET_UPLOAD_URL=https://upload.example.com/meeting-assets
OPENAI_ASSET_PUBLIC_BASE_URL=https://cdn.example.com/meeting-assets
# 如上传接口需要鉴权，填写完整 Authorization 值；不需要可留空或删除。
# OPENAI_ASSET_UPLOAD_AUTHORIZATION=Bearer your-upload-token

# 备用：如果暂时没有素材仓库，也可以把本工具用 ngrok/cloudflared 暴露为公网 HTTPS 地址。
# OPENAI_ASSET_BASE_URL=https://your-public-tool.example

# 如果中转站支持 OpenAI 兼容多图编辑接口，也可改用：
# OPENAI_IMAGE_MODE=images

# 如果内部网关暴露的是非 OpenAI 兼容自定义图片接口，可配置：
# OPENAI_IMAGE_MODE=custom
# OPENAI_IMAGE_ENDPOINT=https://your-internal-gateway.example.com/image2
